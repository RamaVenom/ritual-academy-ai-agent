# GROQ_API_KEY is provided via Replit Secrets — do not set it here.
# Uncomment and set the line below only if running outside Replit.
# GROQ_API_KEY=

# Optional: Groq model to use (defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Maximum tokens per response
MAX_TOKENS=4096

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
